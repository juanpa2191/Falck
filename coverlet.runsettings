<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuración de cobertura para "dotnet test" con el colector XPlat Code Coverage.
  Excluye las migraciones generadas por EF Core para que el número reportado
  refleje únicamente el código escrito a mano.
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <ExcludeByFile>**/Persistence/Migrations/*.cs</ExcludeByFile>
          <Exclude>[*]Falck.Infrastructure.Persistence.Migrations.*</Exclude>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
